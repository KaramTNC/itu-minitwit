networks:
  {{ app_name }}-network:
    name: {{ app_name }}-network

# Limit log size per container
x-logging: &default_logging
  logging:
    driver: "json-file"
    options:
      max-size: "10m"
      max-file: "3"

services:
  grafana-alloy:
    <<: *default_logging
    image: grafana/alloy
    container_name: grafana-alloy
    ports:
      - "12345:12345"
    volumes:
      - ./config.alloy:/etc/alloy/config.alloy
      - /var/run/docker.sock:/var/run/docker.sock
      - /var/lib/docker/containers:/var/lib/docker/containers:ro
    networks:
      - {{ app_name }}-network
    command: run --server.http.listen-addr=0.0.0.0:12345 --storage.path=/var/lib/alloy/data /etc/alloy/config.alloy
    restart: unless-stopped

  itu-api-server:
    <<: *default_logging
    image: {{ docker_username }}/itu-api-server:{{ IMAGE_TAG | default("latest") }}
    build:
      context: .
      dockerfile: docker/api/Dockerfile
    container_name: api
    ports:
      - "8080:8080"
      - "9185:9185"
    env_file:
      - .env
    environment:
      - ASPNETCORE_URLS=http://+:8080
      - OTEL_PROMETHEUS_URI_PREFIX=http://*:9185/
    networks:
      - {{ app_name }}-network
    restart: unless-stopped

  itu-web-server:
    <<: *default_logging
    image: {{ docker_username }}/itu-web-server:{{ IMAGE_TAG | default("latest") }}
    build:
      context: .
      dockerfile: docker/web/Dockerfile
    container_name: web
    ports:
      - "5001:5001"
      - "9184:9184"
    env_file:
      - .env
    environment:
      - ASPNETCORE_URLS=http://+:5001
      - OTEL_PROMETHEUS_URI_PREFIX=http://*:9184/
    networks:
      - {{ app_name }}-network
    restart: unless-stopped
